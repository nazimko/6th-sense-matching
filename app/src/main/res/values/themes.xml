<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Ana App Teması -->
    <style name="Theme._6thSense" parent="android:Theme.Material.Light.NoActionBar">
    </style>

    <!-- Splash Screen Teması -->
    <style name="Theme._6thSense.Starting" parent="Theme.SplashScreen">

        <!-- Arka plan -->
        <item name="windowSplashScreenBackground">@color/splash_background</item>

        <!-- Ortadaki icon -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/image</item>

        <!-- Animasyon süresi -->
        <item name="windowSplashScreenAnimationDuration">2000</item>

        <!-- Splash sonrası geçilecek tema -->
        <item name="postSplashScreenTheme">@style/Theme._6thSense</item>

    </style>

</resources>
